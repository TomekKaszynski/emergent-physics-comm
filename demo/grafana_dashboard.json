{
  "dashboard": {
    "id": null,
    "uid": "wmcp-protocol",
    "title": "WMCP Protocol Dashboard",
    "tags": ["wmcp", "protocol", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1, "type": "stat", "title": "Active Agents",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "targets": [{"expr": "wmcp_agents_total", "legendFormat": "agents"}]
      },
      {
        "id": 2, "type": "stat", "title": "Total Messages",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "targets": [{"expr": "wmcp_messages_total", "legendFormat": "messages"}]
      },
      {
        "id": 3, "type": "gauge", "title": "Accuracy",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "targets": [{"expr": "wmcp_accuracy", "legendFormat": "accuracy"}],
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [
          {"value": 0, "color": "red"}, {"value": 0.6, "color": "yellow"}, {"value": 0.8, "color": "green"}
        ]}}}
      },
      {
        "id": 4, "type": "gauge", "title": "PosDis",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "targets": [{"expr": "wmcp_posdis", "legendFormat": "posdis"}],
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "thresholds": {"steps": [
          {"value": 0, "color": "red"}, {"value": 0.3, "color": "yellow"}, {"value": 0.5, "color": "green"}
        ]}}}
      },
      {
        "id": 5, "type": "timeseries", "title": "Latency (ms)",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {"expr": "wmcp_latency_mean_ms", "legendFormat": "mean"},
          {"expr": "wmcp_latency_p95_ms", "legendFormat": "p95"}
        ]
      },
      {
        "id": 6, "type": "stat", "title": "Drift Detected",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 4},
        "targets": [{"expr": "wmcp_drift_detected", "legendFormat": "drift"}],
        "fieldConfig": {"defaults": {"thresholds": {"steps": [
          {"value": 0, "color": "green"}, {"value": 1, "color": "red"}
        ]}}}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
